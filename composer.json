{
  "name": "akabihno/lingwhaat",
  "description": "description",
  "minimum-stability": "stable",
  "license": "CC-BY-SA and GFDL",
  "authors": [
    {
      "name": "akabihno",
      "email": "arsenijs.kabihno@gmail.com"
    }
  ],
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "bump-after-update": true,
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php84": "*"
  },
  "require": {
    "php": "^8.5",
    "ext-pdo": "*",
    "doctrine/dbal": "^3.10.5",
    "doctrine/doctrine-bundle": "^2.18.3",
    "doctrine/doctrine-migrations-bundle": "^3.7.0",
    "doctrine/orm": "^3.6.7",
    "symfony/config": "^7.4.10",
    "symfony/console": "^7.4.13",
    "symfony/dependency-injection": "^7.4.13",
    "symfony/dotenv": "^7.4.11",
    "symfony/flex": "^2.11.0",
    "symfony/framework-bundle": "^7.4.13",
    "symfony/http-foundation": "^7.4.13",
    "symfony/http-kernel": "^7.4.13",
    "symfony/http-client": "^7.4.13",
    "symfony/routing": "^7.4.13",
    "symfony/runtime": "^7.4.13",
    "symfony/twig-bundle": "^7.4.8",
    "symfony/yaml": "^7.4.13",
    "symfony/asset": ">=8.1.0",
    "symfony/monolog-bundle": "^3.11.2",
    "symfony/uid": "^7.4.9",
    "symfony/rate-limiter": "v7.2.0",
    "symfony/lock": "^7.4.9",
    "symfony/messenger": "^7.4.12",
    "symfony/redis-messenger": "^7.4.8",
    "symfony/doctrine-messenger": "^7.4.6",
    "symfony/scheduler": "^7.4.13",
    "symfony/var-exporter": "^7.4.9",
    "twig/twig": "^3.27.1",
    "vlucas/phpdotenv": ">=5.6.3",
    "ext-mbstring": "*",
    "nelmio/api-doc-bundle": "^5.10.3",
    "promphp/prometheus_client_php": "^2.15.1",
    "ruflin/elastica": "^8.2.0",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-redis": "*"
  },
  "require-dev": {
    "psalm/plugin-symfony": "^5.3",
    "symfony/maker-bundle": "^1.67.0",
    "vimeo/psalm": "^6.16"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "psalm": "psalm --no-progress",
    "psalm:baseline": "psalm --no-progress --set-baseline=psalm-baseline.xml"
  }
}
